# Seecript · 后端配置示例
# -------------------------------------------------------------------
# 用法：cp server/.env.example server/.env，然后按需填值。
# 真值 .env 已在 .gitignore，不会被 git 跟踪——本文件只放占位/默认值。
# 详细字段含义见 server/app/config.py。
# -------------------------------------------------------------------

# === Server ===
# 本地 dev 默认 127.0.0.1:8090，生产 nginx 反代时可绑 0.0.0.0
HOST=127.0.0.1
PORT=8090

# === LLM ===
# mock | doubao_ark | deepseek
LLM_PROVIDER=mock

# --- 火山方舟（doubao_ark）— 4 个 AI 干预点共用同一把 API Key ---
# 申请：https://console.volcengine.com/ark/region:ark+cn-beijing/apiKey
# 模型 / 推理点：https://console.volcengine.com/ark/region:ark+cn-beijing/model
#
# 切到方舟后建议把下面 4 个 *_PROVIDER 同时改 doubao_ark：
#   LLM_PROVIDER=doubao_ark      # 段落结构 / Hook / CTA / 文案补全
#   VLM_PROVIDER=doubao_ark      # 关键帧打标
#   T2I_PROVIDER=doubao_ark      # 缺口画面文生图（Seedream）
#   T2V_PROVIDER=doubao_ark      # 长视频首尾帧扩展（Seedance）
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# 字段值既可填官方 model id（如 doubao-seed-2-0-lite），也可填自建推理点 ep-id（如 ep-20260508213828-7ntjl）
ARK_LLM_MODEL=doubao-seed-2-0-lite
ARK_VLM_MODEL=doubao-seed-1-6-vision
ARK_T2I_MODEL=doubao-seedream-4-0
ARK_T2V_MODEL=doubao-seedance-1-0-pro

# --- DeepSeek（旧通道，向后兼容；不接火山方舟时可走这里） ---
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# --- 共享参数 ---
LLM_TEMPERATURE=0.7
LLM_TIMEOUT_SECONDS=60
LLM_MAX_TOKENS=2048

# === VLM / T2I / T2V（默认全 mock，开机即可端到端跑） ===
# 切到 doubao_ark 时自动复用上面的 ARK_API_KEY + ARK_*_MODEL
VLM_PROVIDER=mock
T2I_PROVIDER=mock
T2V_PROVIDER=mock
T2V_MAX_PROMPT_CHARS=500
T2V_MOCK_DURATION_SECONDS=8

# === ASR（豆包大模型录音文件识别 · 极速版）===
# mock | doubao
ASR_PROVIDER=mock
DOUBAO_API_KEY=
# 资源 ID 必须为极速版（_turbo），普通版会触发 401
DOUBAO_RESOURCE_ID=volc.bigasr.auc_turbo
DOUBAO_RECOGNIZE_URL=https://openspeech.bytedance.com/api/v3/auc/bigmodel/recognize/flash
ASR_TIMEOUT_SECONDS=60

# === CORS ===
# 生产建议改为具体的域名列表（逗号分隔），本地 dev 用 *
CORS_ORIGINS=*

# === Logging ===
LOG_LEVEL=INFO
