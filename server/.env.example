# Seecript · 后端配置示例
# -------------------------------------------------------------------
# 用法：cp server/.env.example server/.env，然后按需填值。
# 真值 .env 已在 .gitignore，不会被 git 跟踪——本文件只放占位/默认值。
# 详细字段含义见 server/app/config.py。
# -------------------------------------------------------------------

# === Server ===
# 本地 dev 默认 127.0.0.1:8090，生产 nginx 反代时可绑 0.0.0.0
HOST=127.0.0.1
PORT=8090

# === LLM (DeepSeek)，6 个 AI 干预点的核心 ===
# mock | deepseek
LLM_PROVIDER=mock
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
LLM_TEMPERATURE=0.7
LLM_TIMEOUT_SECONDS=60
LLM_MAX_TOKENS=2048
# 各 JSON 端点 completion 上限（避免 DeepSeek 输出被截断导致「未返回合法 JSON」）
LLM_SKELETON_MAX_TOKENS=4096
LLM_PERSONA_MAX_TOKENS=3072
LLM_SCRIPT_MAX_TOKENS=6144
LLM_SEO_MAX_TOKENS=3072
LLM_COMMENTS_MAX_TOKENS=4096
LLM_QA_MAX_TOKENS=2048

# === ASR（豆包大模型录音文件识别 · 极速版）===
# mock | doubao
ASR_PROVIDER=mock
DOUBAO_API_KEY=
# 资源 ID 必须为极速版（_turbo），普通版会触发 401
DOUBAO_RESOURCE_ID=volc.bigasr.auc_turbo
DOUBAO_RECOGNIZE_URL=https://openspeech.bytedance.com/api/v3/auc/bigmodel/recognize/flash
ASR_TIMEOUT_SECONDS=60

# === T2V（智谱清影，v0.9 起接入；第 7 个 AI 干预点）===
# mock | zhipu
# - mock：开箱即用，本地无任何 key 也能跑通完整 UI（task 8 秒后自动 success）
# - zhipu：需要先到 https://open.bigmodel.cn/usercenter/apikeys 创建 API Key
T2V_PROVIDER=mock
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# 默认 cogvideox-3（与开放平台文档 / 体验中心主推一致；2026.05 官网约 1 元/次，5 或 10 秒）
# 仍可改为 cogvideox-2（约 0.5 元/次·固定约 6 秒）以压低成本——尺寸枚举略有差异，详见 README §2.5
ZHIPU_VIDEO_MODEL=cogvideox-3
# 以下仅在 cogvideox-3 时写入请求体（OpenAPI：fps ∈ {30,60}，duration ∈ {5,10} 秒）
ZHIPU_VIDEO_FPS=30
ZHIPU_VIDEO_DURATION=5
T2V_TIMEOUT_SECONDS=30
# prompt 硬上限——智谱官方 512 字符，留 12 字安全余量
T2V_MAX_PROMPT_CHARS=500
# mock 模式下"假装生成"耗时（秒），用于让前端轮询 UI 真有进度感
T2V_MOCK_DURATION_SECONDS=8

# === CORS ===
# 生产建议改为具体的域名列表（逗号分隔），本地 dev 用 *
CORS_ORIGINS=*

# === Logging ===
LOG_LEVEL=INFO
