# Seecript · 后端配置示例
# -------------------------------------------------------------------
# 用法：cp server/.env.example server/.env，然后按需填值。
# 真值 .env 已在 .gitignore，不会被 git 跟踪——本文件只放占位/默认值。
# 详细字段含义见 server/app/config.py。
# 生产部署：建议 chmod 600 server/.env 锁权限。
# -------------------------------------------------------------------

# === Server ===
# 本地 dev 默认 127.0.0.1:8090；生产 gunicorn 绑 127.0.0.1:5001（nginx 反代到 443）
HOST=127.0.0.1
PORT=8090

# === LLM（多模态：seed-2.0-lite 既做文本也做画面理解）===
# mock | doubao_ark | deepseek
LLM_PROVIDER=mock

# --- 火山方舟（doubao_ark）— 多模态 LLM + Seedance 共用同一个控制台，但 Key 可独立 ---
# 申请：https://console.volcengine.com/ark/region:ark+cn-beijing/apiKey
# 模型 / 推理点：https://console.volcengine.com/ark/region:ark+cn-beijing/model
#
# 切到方舟后同时改：
#   LLM_PROVIDER=doubao_ark      # 段落结构 / Hook/CTA / 文案补全 / 关键帧打标 / 缺口判定（多模态）
#   T2V_PROVIDER=doubao_ark      # 长视频首尾帧扩展 + AIGC 缺口生成（Seedance）
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# 字段值既可填官方 model id（如 doubao-seed-2-0-lite），也可填自建推理点 ep-id（如 ep-20260508213828-7ntjl）
ARK_LLM_MODEL=doubao-seed-2-0-lite
ARK_T2V_MODEL=doubao-seedance-2-0-fast-260128
# Seedance 走独立计费 Key 时填这里；为空则 T2V client 自动回落到 ARK_API_KEY
ARK_T2V_API_KEY=

# --- DeepSeek（旧通道，向后兼容；不接火山方舟时可走这里。仅文本，不能做画面理解） ---
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# --- 共享参数 ---
LLM_TEMPERATURE=0.7
LLM_TIMEOUT_SECONDS=120
LLM_MAX_TOKENS=2048

# === T2V（视频生成，Seedance 2.0 多模态参考帧/参考视频/参考音频）===
# 切到 doubao_ark 时自动复用上面的 ARK_API_KEY + ARK_T2V_MODEL；
# 也可单独配 ARK_T2V_API_KEY 走独立计费。Seedance 2.0 duration 最低 5s（3s 会被拒）。
T2V_PROVIDER=mock
T2V_TIMEOUT_SECONDS=60
T2V_MAX_PROMPT_CHARS=500
T2V_MOCK_DURATION_SECONDS=8
T2V_DEFAULT_RATIO=16:9
T2V_GENERATE_AUDIO=false
T2V_WATERMARK=false

# === ASR（豆包大模型录音文件识别 2.0 · 异步 submit + query）===
# mock | doubao
# 注：流水线先做 librosa 人声 VAD，纯 BGM 视频自动跳过 ASR 调用。
# 2.0 强制 audio.url 公网可达——不再支持 base64 inline，必须配 PUBLIC_AUDIO_BASE_URL。
# 旧的极速版 (volc.bigasr.auc_turbo) 已弃用；2.0 标准资源 ID = volc.bigasr.auc。
ASR_PROVIDER=mock
# 鉴权：新控制台只填 DOUBAO_API_KEY；旧控制台同时填 DOUBAO_API_KEY=AppID + DOUBAO_ACCESS_KEY=AccessToken
DOUBAO_API_KEY=
DOUBAO_ACCESS_KEY=
DOUBAO_RESOURCE_ID=volc.bigasr.auc
DOUBAO_SUBMIT_URL=https://openspeech.bytedance.com/api/v3/auc/bigmodel/submit
DOUBAO_QUERY_URL=https://openspeech.bytedance.com/api/v3/auc/bigmodel/query
# 提供给火山服务端拉音频用。生产环境填 https://<生产域名>（nginx 已反代 /samples /uploads）。
# 本地 dev 用 cloudflared tunnel 临时打洞：cloudflared tunnel --url http://127.0.0.1:8090
PUBLIC_AUDIO_BASE_URL=
ASR_TIMEOUT_SECONDS=120
ASR_POLL_INTERVAL_SECONDS=2
ASR_POLL_MAX_SECONDS=180

# === TTS（口播合成，火山引擎语音合成 v1）===
# mock | volc
# 与 ARK / ASR 完全独立的产品 — 控制台位置：console.volcengine.com → 语音技术 → 语音合成
# 创建应用后会拿到 App ID（短串）+ Access Token（长串），并在应用配置里勾选音色（如 zh_female_qingxin）。
# 不配 → 自动走 mock，合成单调正弦波让链路跑通（人耳听不出文案）。
TTS_PROVIDER=mock
VOLC_TTS_APP_ID=
VOLC_TTS_ACCESS_TOKEN=
VOLC_TTS_ENDPOINT=https://openspeech.bytedance.com/api/v1/tts
VOLC_TTS_CLUSTER=volcano_tts
TTS_DEFAULT_VOICE=zh_female_qingxin
TTS_SAMPLE_RATE=24000
TTS_TIMEOUT_SECONDS=30

# === CORS ===
# 生产改为具体域名（逗号分隔），如 https://seecript.example.com；本地 dev 用 *
CORS_ORIGINS=*

# === Logging ===
LOG_LEVEL=INFO
