; Seecript backend systemd unit (template)
;
; Install steps (run on the production server):
;   sudo cp __PROJECT_DIR__/deploy/seecript-server.service \
;           /etc/systemd/system/seecript-server.service
;   sudo sed -i 's|__PROJECT_DIR__|/opt/seecript|g; s|__RUN_USER__|seecript|g' \
;           /etc/systemd/system/seecript-server.service
;   sudo systemctl daemon-reload
;   sudo systemctl enable --now seecript-server
;
; Health check after start:
;   curl http://127.0.0.1:5001/api/health
;
; The leading semicolons in this header are NOT systemd syntax — they are placed only to
; signal "comments" to readers. systemd ignores any line beginning with `#` or `;`.

[Unit]
Description=Seecript FastAPI backend (gunicorn + uvicorn workers)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=__RUN_USER__
Group=__RUN_USER__
WorkingDirectory=__PROJECT_DIR__/server

# Loaded *before* ExecStart; gives us PORT/LLM_PROVIDER/etc. without exposing them in cmdline.
EnvironmentFile=__PROJECT_DIR__/server/.env

# --workers 1 是必须的：plan_store / project_store / gap_store / material_store / asset_store
# 全是模块级内存单例（JSON 仅做落盘镜像），多 worker 之间内存互不可见——
# 同一份 plan 写在 A 的内存，下个请求落到 B 就 404。
# 真正要并发扩容前需要把 stores 改成集中存储（sqlite/redis），那是 v0.2 的事。
# 1 worker + uvicorn async event loop 已足够 demo / 单用户压测。
#
# `--access-logfile -` / `--error-logfile -` 把日志路由到 journalctl；app 内 logger
# 仍会写 __PROJECT_DIR__/server/logs/ 便于 grep。
# --timeout 120: ASR 异步 query 30s+、Seedance T2V 单段 8-30s、ffmpeg 转码偶尔几十秒；
#   120s 是 nginx 90s 之上的兜底，避免 worker 在长任务期间被 gunicorn 杀掉。
ExecStart=__PROJECT_DIR__/server/venv/bin/gunicorn \
    --workers 1 \
    --worker-class uvicorn.workers.UvicornWorker \
    --bind 127.0.0.1:5001 \
    --timeout 120 \
    --graceful-timeout 30 \
    --access-logfile - \
    --error-logfile - \
    app.main:app

# Graceful shutdown: gunicorn handles SIGTERM by waiting for in-flight requests to finish.
KillSignal=SIGTERM
TimeoutStopSec=35

Restart=on-failure
RestartSec=5
StartLimitBurst=10
StartLimitIntervalSec=60

# Hardening — same defaults we use in chronic-medication-assistant, kept conservative.
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=read-only
# Writable paths — 必须把 server/var 也加上，否则 ProtectSystem=full 会让 app 写入全数 EROFS：
#   server/logs/     — uvicorn / gunicorn 自己的日志（gunicorn 同时 pipe 到 journal）
#   server/var/      — 应用运行时写入：
#                       uploads/    用户上传素材（按 session 隔离）
#                       outputs/    渲染产物 final.mp4
#                       assets/     用户素材库（BGM、参考图、参考视频）
#                       voiceovers/ TTS 合成的口播 wav
#                       projects/   project_store / step_store / plan_store JSON 落盘
#                       aigc_cache/ Seedance T2V 中间分段
ReadWritePaths=__PROJECT_DIR__/server/logs __PROJECT_DIR__/server/var

# stdout/stderr -> journalctl -u seecript-server -f
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
